<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_deliveryslip_firmas" inherit_id="stock.report_delivery_document">
        <!-- Agregar sección de firmas al final del conduce -->
        <xpath expr="//div[@class='page']" position="inside">
            <!-- Obtener firma digital del vendedor desde ir.attachment -->
            <t t-set="default_signature" t-value="env.ref('quotation_met.default_purchase_signature', raise_if_not_found=False)"/>
            <t t-set="signature_image" t-value="default_signature.sudo().datas if default_signature else None"/>

            <!-- FIRMAS: contenidas dentro del row para que page-break-inside: avoid
                 las proteja de cortes entre páginas -->
            <div class="row" style="page-break-inside: avoid; margin-top: 40px; min-height: 160px;">

                <!-- Firma Autorizada con imagen digital posicionada dentro de la columna -->
                <div class="col-4 text-center" style="position: relative; min-height: 160px; padding-right: 10px; padding-left: 10px;">
                    <t t-if="signature_image">
                        <div style="position: absolute; bottom: 30px; left: 0; right: 0; text-align: center;">
                            <img t-att-src="image_data_uri(signature_image)"
                                 style="max-height:80px; max-width:160px;"
                                 alt="Firma Autorizada"/>
                        </div>
                    </t>
                    <div style="position: absolute; bottom: 20px; left: 10px; right: 10px;">
                        <div class="border-bottom border-2 border-dark"></div>
                        <p class="text-center mb-0 mt-2">Firma Autorizada</p>
                    </div>
                </div>

                <!-- Firma Despacho -->
                <div class="col-4 text-center" style="position: relative; min-height: 160px;">
                    <div style="position: absolute; bottom: 20px; left: 10px; right: 10px;">
                        <div class="border-bottom border-2 border-dark" style="max-width: 200px; margin-left: auto; margin-right: auto;"></div>
                        <p class="text-center mb-0 mt-2">Firma Despacho</p>
                    </div>
                </div>

                <!-- Firma Recepcion -->
                <div class="col-4 text-center" style="position: relative; min-height: 160px; padding-right: 10px;">
                    <div style="position: absolute; bottom: 20px; left: 10px; right: 10px;">
                        <div class="border-bottom border-2 border-dark"></div>
                        <p class="text-center mb-0 mt-2">Firma Recepcion</p>
                    </div>
                </div>

            </div>
        </xpath>
    </template>
</odoo>
